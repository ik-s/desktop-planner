# 다른 컴퓨터에서 접속하려면 서버를 켜는 컴퓨터에서 0.0.0.0으로 바꾸세요.
PLANNER_HOST=127.0.0.1
PLANNER_PORT=8787
PLANNER_USERNAME=me
PLANNER_PASSWORD=planner
PLANNER_DATA_FILE=server/data/planner.json
PLANNER_STATIC_DIR=dist
PLANNER_REDIS_KEY=desktop-planner:large-plans
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vite 개발 서버를 쓸 때만 필요합니다. 빌드 앱을 API 서버에서 열면 같은 주소의 /api를 자동으로 씁니다.
VITE_PLANNER_API_URL=http://127.0.0.1:8787
